HOST=127.0.0.1
PORT=8899
APP_BASE_URL=http://127.0.0.1:8899
PRODUCT_NAME=Axion Process OS
SESSION_SECRET=change-this-to-a-long-random-secret

# Internal owner/admin login. KBrenner and MAhmed are also seeded as payment-exempt users in server.mjs.
AXION_ADMIN_USER=owner
AXION_ADMIN_PASSWORD=change-this-owner-password
AXION_LOCAL_PASSWORD_LOGIN=false

# Paywall price: 2,400 EUR Professional Individual per user/year.
AXION_PRICE_CENTS=240000
AXION_CURRENCY=EUR

# Automatic SaaS payment via Stripe Checkout.
# Create these in Stripe Dashboard; never commit real secrets.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional Google login. Google users must already be payment-exempt or have an active license.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ALLOWED_EMAILS=
GOOGLE_ALLOWED_DOMAINS=
